# GitHub 采集必填
GITHUB_TOKEN=github_pat_xxx
# 可选：仅在 repositories 表为空时由 init-db 首次导入
# 初始化后请使用 python pipeline.py repo ... 管理白名单
GITHUB_REPOSITORIES=rust-lang/rust,tokio-rs/tokio
# 数据库必填
DATABASE_URL=mysql+pymysql://github_sentiment:change-me@127.0.0.1:3306/github_sentiment?charset=utf8mb4

# 仅执行 DeepSeek 标注时必填
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 可选
GITHUB_API_URL=https://api.github.com
GITHUB_API_VERSION=2022-11-28
GITHUB_CURSOR_OVERLAP_SECONDS=300
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=5
LABEL_BATCH_SIZE=20
LOG_LEVEL=INFO
